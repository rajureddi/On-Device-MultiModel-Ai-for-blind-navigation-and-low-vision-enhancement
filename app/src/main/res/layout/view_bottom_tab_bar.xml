<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Floating Navigation Container -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">

            <!-- Local Model Tab -->
            <LinearLayout
                android:id="@+id/tab_local_models"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:background="@drawable/tab_background_selector">

                <ImageView
                    android:id="@+id/icon_local_models"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginBottom="2dp"
                    app:tint="@color/tab_color_selector_purple"
                    app:srcCompat="@drawable/ic_u_home" />

                <TextView
                    android:id="@+id/text_local_models"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_name_chats"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/tab_color_selector_purple"/>
            </LinearLayout>

            <!-- Model Market Tab -->
            <LinearLayout
                android:id="@+id/tab_model_market"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:background="@drawable/tab_background_selector">

                <ImageView
                    android:id="@+id/icon_model_market"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginBottom="2dp"
                    app:tint="@color/tab_color_selector_teal"
                    app:srcCompat="@drawable/ic_u_market" />

                <TextView
                    android:id="@+id/text_model_market"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/models_market"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/tab_color_selector_teal"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</merge>